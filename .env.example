# C-HR root env — orchestration cho docker-compose ở root.
# Copy file này sang `.env` rồi điền giá trị thật. KHÔNG commit `.env`.
#
# Mỗi app vẫn có file env riêng:
#   apps/backend/.env       (BE đọc qua @nestjs/config)
#   apps/frontend/.env.local (FE đọc qua Next.js)
# Root `.env` chỉ dùng cho docker-compose.

# ===========================================
# General
# ===========================================
NODE_ENV=development
LOG_LEVEL=debug

# ===========================================
# Postgres
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=c_hr
POSTGRES_PORT=5432

# ===========================================
# Redis
# ===========================================
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# Backend (apps/backend)
# ===========================================
BACKEND_PORT=8000
API_PREFIX=api/v1
API_BASE_URL=http://localhost:8000
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CORS_ORIGIN=http://localhost:3000
AUTH_ACCESS_COOKIE_NAME=access_token
AUTH_REFRESH_COOKIE_NAME=refresh_token
COOKIE_SAMESITE=lax
ADMIN_EMAIL=admin@c-hr.local
ADMIN_PASSWORD=Admin@123456

# ===========================================
# Frontend (apps/frontend) — chỉ dùng nếu sau này dockerize FE
# ===========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
