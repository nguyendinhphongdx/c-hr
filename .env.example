# =============================================================================
# C-HR — root environment template
# Copy to .env and fill in production values before running docker compose.
# This file is loaded automatically by all docker-compose includes (postgres,
# redis, backend, frontend).
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=c_hr
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Public deployment URLs
# -----------------------------------------------------------------------------
# Hostname-only values used by Traefik Host() rules.
API_HOST=hrm.cmcai.vn
FRONTEND_HOST=hrm.cmcai.vn

# Public origins include the scheme. They may share one domain today and
# point to separate DNS records later without changing application code.
API_BASE_URL=http://hrm.cmcai.vn
FRONTEND_URL=http://hrm.cmcai.vn
API_PREFIX=api/v1

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Set true after HTTPS/TLS is configured.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

STORAGE_TYPE=local
# S3 / MinIO — AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY are reused as
# MinIO root credentials when services/minio is included.
# AWS_S3_ENDPOINT=http://minio:9000   # set this to use MinIO instead of AWS S3
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_SECURE=false

# SSO (Microsoft Entra — leave empty to disable)
MS_SSO_TENANT_ID=common
MS_SSO_CLIENT_ID=
MS_SSO_CLIENT_SECRET=

# Recruitment
RECRUITMENT_CREDENTIALS_KEY=change-me-to-a-long-random-string
TALENT_VN_BASE_URL=https://api.talent.rework.vn
TOPCV_BASE_URL=https://api.topcv.vn
