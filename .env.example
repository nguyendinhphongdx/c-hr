# =============================================================================
# C-HR — root environment template
# Copy to .env and fill in production values before running docker compose.
# This file is loaded automatically by all docker-compose includes (postgres,
# redis, backend, frontend).
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=c_hr
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
API_BASE_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

STORAGE_TYPE=local

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_SECURE=false

# SSO (Microsoft Entra — leave empty to disable)
MS_SSO_TENANT_ID=common
MS_SSO_CLIENT_ID=
MS_SSO_CLIENT_SECRET=

# Recruitment
RECRUITMENT_CREDENTIALS_KEY=change-me-to-a-long-random-string
TALENT_VN_BASE_URL=https://api.talent.rework.vn
TOPCV_BASE_URL=https://api.topcv.vn

# -----------------------------------------------------------------------------
# Frontend (next-runtime-env — no rebuild needed when changed)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
