# ===========================================
# APP
# ===========================================
NODE_ENV=development
PORT=8000
API_PREFIX=api/v1
API_BASE_URL=http://localhost:8000
LOG_LEVEL=debug

# ===========================================
# DATABASE
# ===========================================
# Default: Postgres 16 (matches services/postgres). Provider được cấu hình
# trong prisma/schema.prisma — đổi qua: pnpm db:switch <postgresql|mysql|sqlite>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/c_hr

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# JWT
# ===========================================
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ===========================================
# CORS & COOKIES
# ===========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
COOKIE_DOMAIN=
# Cookie-based auth: BE sets httpOnly cookies on login/register/refresh.
# JwtStrategy extracts tokens from cookie first, Bearer header as fallback.
AUTH_ACCESS_COOKIE_NAME=access_token
AUTH_REFRESH_COOKIE_NAME=refresh_token
# Auto = true in production, false otherwise. Override here if needed.
COOKIE_SECURE=
# lax | strict | none  (use 'none' + secure=true for cross-site)
COOKIE_SAMESITE=lax

# ===========================================
# STORAGE (local | s3 | gcs)
# ===========================================
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# S3 (only when STORAGE_TYPE=s3)
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCS (only when STORAGE_TYPE=gcs)
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_KEY_FILE=

# ===========================================
# MAIL (SMTP)
# ===========================================
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_SECURE=false

# ===========================================
# ADMIN
# ===========================================
ADMIN_EMAIL=admin@c-hr.local
ADMIN_PASSWORD=Admin@123456

# ===========================================
# RECRUITMENT (F11) — job board integration
# ===========================================
# Secret used to AES-encrypt stored API credentials (talent.vn / TopCV
# token + webhook secret). Any non-empty string; rotated → all stored
# credentials must be re-pasted.
RECRUITMENT_CREDENTIALS_KEY=change-me-to-a-long-random-string
# talent.vn API base URL (override per environment).
TALENT_VN_BASE_URL=https://api.talent.rework.vn
# TopCV API base URL — confirm with TopCV BD before going live.
TOPCV_BASE_URL=https://api.topcv.vn

# ===========================================
# SSO — Single Sign-On (Microsoft Entra ID, shared multi-tenant app)
# ===========================================
# C-HR registers ONE Entra app in its own Azure tenant marked
# "Accounts in any organizational directory + personal accounts"
# (multi-tenant). All Org users sign in with their work Microsoft
# account through this single app — no per-Org Azure setup needed.
#
# Leave clientId/clientSecret empty to disable SSO in this deployment.
#
# Authority tenant — `common` accepts any Microsoft account (work +
# personal), `organizations` accepts only work/school, or a single
# tenant GUID locks the deployment to one customer.
MS_SSO_TENANT_ID=common
MS_SSO_CLIENT_ID=
MS_SSO_CLIENT_SECRET=
# Externally-reachable origin of the frontend — BE redirects user here
# after a successful SSO callback (vd https://app.c-hr.com). Different
# origin from API_BASE_URL in typical multi-host SaaS deployments.
FRONTEND_URL=http://localhost:3000
# Note: the OAuth redirect_uri uses API_BASE_URL — set that to the
# public origin of THIS backend and whitelist
# `<API_BASE_URL>/api/v1/sso/entra/callback` in the Azure app's
# Authentication → Web → Redirect URIs.
