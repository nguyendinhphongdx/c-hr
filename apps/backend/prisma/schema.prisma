// To switch DB engine: `pnpm db:switch <postgresql|mysql|sqlite>`
// (Updates the `provider` line below. Migrations are engine-specific —
//  delete prisma/migrations/ then `pnpm prisma:migrate` after switching.)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role hierarchy: sysowner ⊃ admin (Org) ⊃ appadmin (per-app, see AppAdmin) ⊃ user.
// See docs/decisions/0003-no-permission-engine.md.
enum Role {
  sysowner
  admin
  user
}

// Bounded contexts that ship as separate "apps" inside an Organization.
// Add new codes when scaffolding the matching apps/<context>/ folder.
enum AppCode {
  HRM
  RECRUITMENT
}

// Polymorphic key/value store for per-user / per-org / per-employee
// settings (calendar defaults, notifications, theme...). Same shape as
// Comment/Activity (scope+scopeId+key) — see core/preference module.
enum PreferenceScope {
  USER
  ORG
  EMPLOYEE
}

model Preference {
  id        String          @id @default(uuid())
  scope     PreferenceScope
  scopeId   String          @map("scope_id")
  key       String
  value     Json
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([scope, scopeId, key])
  @@index([scope, scopeId])
  @@map("preferences")
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DeviceBrand {
  ZKTECO
  HIKVISION
  SUPREMA
  OTHER
}

enum AttendanceSource {
  DEVICE
  CORRECTION
  MANUAL_HR
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  timezone  String    @default("Asia/Ho_Chi_Minh")
  currency  String    @default("VND")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users                User[]
  jobs                 Job[]
  candidates           Candidate[]
  applications         Application[]
  jobBoardIntegrations JobBoardIntegration[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  name           String?
  avatar         String?
  // Personal title set by the user (e.g. "Senior Engineer"). Distinct from
  // Employee.title (the formal job title set by HR).
  title          String?
  // Personal info — moved here from Employee so it travels with the
  // person, not the employment record.
  dob            DateTime?
  gender         Gender?
  phone          String?
  role           Role      @default(user)
  // Null for sysowner (no Org). Required for role=admin/user — enforced in app code.
  organizationId String?   @map("organization_id")
  // 1-1 link to Employee. Null until HR provisions the employee record.
  employeeId     String?   @unique @map("employee_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  employee     Employee?     @relation(fields: [employeeId], references: [id])
  appAdmins    AppAdmin[]
  comments     Comment[]
  activities   Activity[]

  eventsOwned      Event[]         @relation("EventOwner")
  eventsCreated    Event[]         @relation("EventCreatedBy")
  eventAttendances EventAttendee[] @relation("EventAttendee")

  projectsOwned      Project[]       @relation("ProjectOwner")
  projectMemberships ProjectMember[] @relation("ProjectMember")

  tasksAssigned Task[]        @relation("TaskAssignee")
  tasksReported Task[]        @relation("TaskReporter")
  taskWatching  TaskWatcher[] @relation("TaskWatcher")
  taskTimers    TaskTimer[]   @relation("TaskTimerUser")

  jobsCreated       Job[]       @relation("JobCreatedBy")
  jobsHiring        Job[]       @relation("JobHiringManager")
  candidatesCreated Candidate[] @relation("CandidateCreatedBy")
  /// 1-1 back-relation when a candidate is hired and linked to a User.
  candidateAccount  Candidate?  @relation("CandidateUser")

  @@map("users")
}

// Per-app admin grant for users with role=user. Users with role=admin or
// sysowner inherit appadmin permissions (no record needed for them).
// See docs/decisions/0003-no-permission-engine.md.
model AppAdmin {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  appCode        AppCode  @map("app_code")
  // The user (admin Org) who granted this. Null if granted via seed/CLI.
  grantedBy      String?  @map("granted_by")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId, appCode])
  @@index([organizationId, appCode])
  @@map("app_admins")
}

// Append-only log of audit-relevant actions (org structure changes, permission
// grants, approval workflow). Written async by AuditInterceptor.
// See docs/decisions/0002-audit-log.md.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  actorIpAddress String?  @map("actor_ip_address")
  actorUserAgent String?  @map("actor_user_agent")
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  diff           Json?
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// Phòng ban — nested via parentId, owns a manager (Employee). Source of
// truth for the org chart per ADR 0004.
model Department {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  parentId       String?   @map("parent_id")
  managerId      String?   @map("manager_id")
  name           String
  /// Optional human-friendly code (e.g. "ENG-01"). Unique within an Org when set.
  code           String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  manager   Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  employees Employee[]   @relation("EmployeeDepartment")

  managedResources Resource[] @relation("ResourceDepartment")
  jobs             Job[]      @relation("JobDepartment")

  @@unique([organizationId, code])
  @@index([organizationId, parentId])
  @@index([organizationId, managerId])
  @@map("departments")
}

// Hồ sơ nhân viên trong Org. 1-1 với User qua User.employeeId (FK lives
// on User; Employee.user is the back-relation only — domain.md keeps a
// single source of truth for the link).
//
// Personal info (name, email, dob, gender, phone) lives on User. Employee
// only carries employment-record fields (title, dept, hireDate, status).
model Employee {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  departmentId    String?        @map("department_id")
  /// Required, unique within an Org. Generated by HR (e.g. "EMP-0001").
  code            String
  /// Formal job title set by HR. Distinct from User.title (personal).
  title           String?
  hireDate        DateTime?      @map("hire_date")
  terminationDate DateTime?      @map("termination_date")
  status          EmployeeStatus @default(ACTIVE)
  /// Lương cơ bản theo hợp đồng — VND. HR set khi onboard / raise.
  /// Có thể override per PayrollItem nếu tháng đó đặc biệt.
  baseSalary      Decimal?       @map("base_salary") @db.Decimal(15, 2)
  /// Số người phụ thuộc cho giảm trừ gia cảnh thuế TNCN.
  dependents      Int            @default(0)
  /// Vùng I/II/III/IV — quyết định mức trần đóng BHXH/BHYT/BHTN.
  region          RegionTier     @default(REGION_I)
  /// Mã số thuế cá nhân (10 chữ số).
  taxCode         String?        @map("tax_code") @db.VarChar(10)
  /// Số sổ BHXH.
  bhxhCode        String?        @map("bhxh_code") @db.VarChar(20)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  department         Department?     @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  managedDepartments Department[]    @relation("DepartmentManager")
  /// 1-1 back-relation. FK is on User.employeeId.
  user               User?
  attendanceLogs     AttendanceLog[]

  requestsAsRequester Request[] @relation("RequestRequester")
  requestsAsApprover  Request[] @relation("RequestApprover")

  calendarFollowers CalendarFollow[] @relation("CalendarFollowFollower")
  calendarFollowing CalendarFollow[] @relation("CalendarFollowFollowed")

  payrollItems PayrollItem[] @relation("EmployeePayroll")

  /// 1-1 back-relation. FK is on OnboardingPlan.employeeId (unique).
  onboardingPlan OnboardingPlan?

  /// 1-1 back-relation when this employee was promoted from a candidate.
  /// FK is on Candidate.employeeId (unique).
  fromCandidate Candidate? @relation("CandidateEmployee")

  @@unique([organizationId, code])
  @@index([organizationId, departmentId])
  @@index([organizationId, status])
  @@map("employees")
}

// Lịch làm việc — mỗi Org có 1 schedule isDefault=true. Áp cho mọi
// employee (MVP). Thêm Employee.workScheduleId chỉ khi cần override.
model WorkSchedule {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  isDefault      Boolean   @default(false) @map("is_default")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  shifts WorkShift[]

  @@index([organizationId, isDefault])
  @@map("work_schedules")
}

// Một ca làm trong schedule: "Ca chính T2-T6", "Sáng T7", "Ca đêm".
// startTime/endTime dạng "HH:MM" 24h. crossesMidnight=true khi end <= start.
model WorkShift {
  id               String   @id @default(uuid())
  workScheduleId   String   @map("work_schedule_id")
  name             String
  startTime        String   @map("start_time")
  endTime          String   @map("end_time")
  /// ISO weekdays: 1=Mon ... 7=Sun. MVP constraint: shifts trong cùng
  /// schedule không được trùng day — validated ở service layer.
  daysOfWeek       Int[]    @map("days_of_week")
  breakMinutes     Int      @default(0) @map("break_minutes")
  lateGraceMinutes Int      @default(15) @map("late_grace_minutes")
  crossesMidnight  Boolean  @default(false) @map("crosses_midnight")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)

  @@map("work_shifts")
}

// Đầu đọc chấm công đăng ký với Org. Push events qua HTTP với token.
model AttendanceDevice {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  brand          DeviceBrand
  serial         String
  /// Bumped khi regenerate-token để invalidate JWT cũ. JWT push include `v`,
  /// server reject nếu `v != device.version`.
  version        Int         @default(1)
  name           String
  ipAddress      String?     @map("ip_address")
  lastSeenAt     DateTime?   @map("last_seen_at")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  logs AttendanceLog[]

  @@unique([organizationId, serial])
  @@map("attendance_devices")
}

// 1 row = 1 ngày của 1 employee. Push lần thứ nhất tạo row, push tiếp theo
// update checkInAt = MIN, checkOutAt = MAX. Replay của cùng eventLogId là
// no-op qua unique (deviceId, eventLogId).
model AttendanceLog {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  /// Nullable: events từ device có employeeCode chưa map được Employee row
  /// (HR chưa tạo) sẽ được lưu với employeeId=null + employeeCode=<raw>.
  /// Khi Employee được tạo/update với code đó → reconcile gán employeeId.
  employeeId     String?          @map("employee_id")
  /// Raw employee code từ device payload. Lưu cho mọi row có nguồn từ device,
  /// để reconcile được orphan logs sau khi Employee tạo (Postgres NULL trong
  /// unique không chặn → nhiều orphan rows / day cùng tồn tại OK).
  employeeCode   String?          @map("employee_code")
  date           DateTime         @db.Date
  checkInAt      DateTime?        @map("check_in_at")
  checkOutAt     DateTime?        @map("check_out_at")
  source         AttendanceSource
  deviceId       String?          @map("device_id")
  /// Idempotency key gửi kèm payload từ device (event id nội bộ của nó).
  /// Cặp (deviceId, eventLogId) unique → replay không tạo dup.
  eventLogId     String?          @map("event_log_id")
  note           String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  employee Employee?         @relation(fields: [employeeId], references: [id])
  device   AttendanceDevice? @relation(fields: [deviceId], references: [id])

  @@unique([employeeId, date])
  @@unique([deviceId, eventLogId])
  @@index([organizationId, date])
  @@index([organizationId, employeeCode])
  @@map("attendance_logs")
}

/// Public holidays / org-specific days off. Used by TimesheetReportService
/// to classify OT into weekday / weekend / holiday buckets per VN labor
/// law (100% / 200% / 300% multipliers). HR enters per year — no auto-seed.
model Holiday {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  /// Single date (no range). For multi-day holidays, HR creates one row per day.
  date           DateTime  @db.Date
  /// Vietnamese name e.g. "Tết Dương lịch", "Quốc Khánh".
  name           String    @db.VarChar(127)
  /// `true` = NLĐ được nghỉ có lương. `false` = ngày lễ nhưng đi làm tính
  /// như ngày thường (rare — for org-specific commemorations).
  isPaid         Boolean   @default(true) @map("is_paid")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@unique([organizationId, date])
  @@index([organizationId, date, deletedAt])
  @@map("holidays")
}

// ──────────────────────────────────────────────────────────────────────
// Universal Request engine (F5) — replaces F4's per-type tables.
// Một bảng `requests` với polymorphic `data: Json` validated theo
// `RequestGroup.fieldsSchema`. Side-effects khi approve dispatch theo
// group code (registry trong src/apps/requests/side-effects/).
// Xem ADR 0006.
// ──────────────────────────────────────────────────────────────────────

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// Định nghĩa loại đơn — system-wide (1 record / code chung mọi Org).
// MVP seed cứng (leave, checkin, checkout). Form-builder UI cho admin
// Org tự thêm/sửa schema sẽ làm sau (xem F5.2 trong plans/features.md).
model RequestGroup {
  id           String   @id @default(uuid())
  /// "leave", "checkin", "checkout", ... — unique system-wide.
  code         String   @unique
  name         String
  description  String?
  /// JSON theo dạng { fields: [{ key, label, type, required, options?, ... }] }.
  /// BE validate request.data trước save; FE dùng render dynamic form.
  fieldsSchema Json     @map("fields_schema")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  requests Request[]

  @@map("request_groups")
}

// Mọi đơn từ. data là object theo group.fieldsSchema (vd leave có
// type/startDate/endDate; checkin có date/requestedCheckInAt/reason; ...).
model Request {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  groupId        String        @map("group_id")
  requesterId    String        @map("requester_id")
  approverId     String?       @map("approver_id")
  status         RequestStatus @default(PENDING)
  title          String?       @map("title")
  data           Json
  decisionNote   String?       @map("decision_note")
  decidedAt      DateTime?     @map("decided_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  group     RequestGroup @relation(fields: [groupId], references: [id])
  requester Employee     @relation("RequestRequester", fields: [requesterId], references: [id])
  approver  Employee?    @relation("RequestApprover", fields: [approverId], references: [id])

  @@index([organizationId, requesterId])
  @@index([organizationId, approverId, status])
  @@index([organizationId, groupId, status])
  @@map("requests")
}

// Generic comment — gắn vào bất kỳ object nào (Request, Employee, ...).
// objectType + objectId là pointer thuần (không FK) để giữ generic. Bảng
// tách khỏi `activities` vì comment mutable + body lớn (HTML), activity
// append-only + payload nhẹ. ADR/plan: F6 trong docs/plans/features.md.
model Comment {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  /// Pascal-case Prisma model name: "Request", "Employee", ...
  objectType String @map("object_type")
  objectId   String @map("object_id")

  userId   String @map("user_id")
  bodyHtml String @map("body_html")
  bodyText String @map("body_text")
  mentions Json?

  parentId String?   @map("parent_id")
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  isInternal Boolean @default(false) @map("is_internal")

  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([organizationId, objectType, objectId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

// Generic tag — gắn vào bất kỳ object nào (Task, Project, Employee, Event,
// Resource, ...). objectType + objectId là pointer thuần (không FK) để giữ
// generic — pattern giống Comment/Activity. MVP: tag thuộc về Org, scope=null
// (gắn được vào mọi loại object). Phase 1A — Tag library.
model Tag {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String    @db.VarChar(63)
  color          String    @db.VarChar(9)
  /// `null` = global tag (gắn được vào mọi objectType). Giá trị (vd "Task")
  /// để giới hạn 1 loại object. MVP dùng null cho mọi tag.
  scope          String?   @db.VarChar(31)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  assignments TagAssignment[]

  @@unique([organizationId, scope, name])
  @@index([organizationId, deletedAt])
  @@map("tags")
}

model TagAssignment {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  tagId          String   @map("tag_id")
  /// "Task" | "Project" | "Employee" | "Event" | "Resource" | ...
  /// Pointer thuần — không FK (giống Comment.objectType/objectId).
  objectType     String   @map("object_type") @db.VarChar(31)
  objectId       String   @map("object_id")
  createdById    String   @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, objectType, objectId])
  @@index([organizationId, objectType, objectId])
  @@index([organizationId, tagId])
  @@map("tag_assignments")
}

// Generic activity — append-only event log per object. Naming:
// "<object>.<verb>" (e.g. "request.commented", "request.approved").
// Side-effects nest under "<object>.side_effect.<name>". Distinct from
// `audit_logs` (admin compliance) — activities is for user-facing UX.
model Activity {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  objectType  String  @map("object_type")
  objectId    String  @map("object_id")
  /// Snapshot label for the feed (e.g. request title) — survives target rename.
  objectLabel String? @map("object_label")

  action String

  /// Null when the action is system-driven (cron, webhook, side-effect).
  userId   String? @map("user_id")
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, objectType, objectId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([action])
  @@map("activities")
}

// ──────────────────────────────────────────────────────────────────────
// Calendar (Feature 7) — MVP Phase 7.1
//
// Calendar là unified render layer. Sở hữu Event (cuộc họp + booking
// trong tương lai). MVP: single events only — không recurrence, không
// resource, không external sync, không follow. Các phần đó tách PR sau.
// ──────────────────────────────────────────────────────────────────────

enum EventStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
}

enum EventVisibility {
  DEFAULT
  PUBLIC
  PRIVATE
  /// Người theo dõi chỉ thấy slot bận, không thấy nội dung.
  BUSY_ONLY
}

enum AttendeeResponse {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum EventProvider {
  LOCAL
  GOOGLE
  MICROSOFT
}

model Event {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  /// Owner = User sở hữu event (khác createdBy nếu admin tạo thay).
  /// Dùng User thay Employee — calendar đi theo người, không theo
  /// employment record (Employee có thể bị terminate/soft-delete;
  /// sysowner cũng không có Employee).
  ownerId     String @map("owner_id")
  createdById String @map("created_by_id")

  title         String  @db.VarChar(511)
  description   String? @db.Text
  location      String? @db.VarChar(1023)
  /// Conference URL (Google Meet / Zoom / Teams). Local v1: free-text.
  conferenceUrl String? @map("conference_url") @db.VarChar(1023)

  isAllDay Boolean  @default(false) @map("is_all_day")
  startAt  DateTime @map("start_at")
  /// Exclusive end ([start, end) — Google convention).
  endAt    DateTime @map("end_at")

  status     EventStatus     @default(CONFIRMED)
  visibility EventVisibility @default(DEFAULT)
  /// Override visibility: nobody but owner+attendees sees detail.
  isPrivate  Boolean         @default(false) @map("is_private")
  color      String?         @db.VarChar(7)

  /// LOCAL = tạo trong C-HR. GOOGLE/MICROSOFT = pull từ external (Phase 7.4).
  provider     EventProvider @default(LOCAL)
  /// Provider-side event id — set khi sync về.
  externalId   String?       @map("external_id") @db.VarChar(255)
  /// Optimistic concurrency token (etag) — sync correctness.
  externalEtag String?       @map("external_etag") @db.VarChar(127)
  /// RFC 5545 universal id — cross-provider dedupe.
  icalUid      String?       @map("ical_uid") @db.VarChar(511)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  owner     User @relation("EventOwner", fields: [ownerId], references: [id])
  createdBy User @relation("EventCreatedBy", fields: [createdById], references: [id])

  attendees EventAttendee[]
  resources EventResource[]

  @@index([organizationId, startAt, endAt])
  @@index([ownerId, startAt])
  @@index([provider, externalId])
  @@index([icalUid])
  @@map("events")
}

// Internal (User trong cùng Org) hoặc external (email) attendee.
// Một trong 2 phải set — enforce ở service layer (DB cho phép cả 2 null
// vì Prisma không có CHECK constraint cho XOR).
model EventAttendee {
  id      String @id @default(uuid())
  eventId String @map("event_id")

  userId      String? @map("user_id")
  email       String? @db.VarChar(127)
  /// Snapshot tên — cho external attendee không có User record.
  displayName String? @map("display_name") @db.VarChar(127)

  response    AttendeeResponse @default(PENDING)
  isOptional  Boolean          @default(false) @map("is_optional")
  isOrganizer Boolean          @default(false) @map("is_organizer")
  respondedAt DateTime?        @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation("EventAttendee", fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@unique([eventId, email])
  @@index([userId, response])
  @@map("event_attendees")
}

// ──────────────────────────────────────────────────────────────────────
// F7.2 — Resources & booking
//
// Resource = phòng họp / thiết bị / xe etc. Booking = N:M join từ Event
// sang Resource (1 event book được nhiều resource cùng lúc, vd phòng +
// máy chiếu). Conflict trên cùng resource là HARD (block) — khác với
// conflict trên người (soft warn) vì 1 phòng không thể chiếm song song.
// ──────────────────────────────────────────────────────────────────────

enum ResourceKind {
  ROOM
  EQUIPMENT
  VEHICLE
}

model Resource {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  kind        ResourceKind
  name        String       @db.VarChar(127)
  description String?      @db.Text
  /// Floor/building cho ROOM, garage cho VEHICLE...
  location    String?      @db.VarChar(255)
  /// Chỉ ý nghĩa với ROOM.
  capacity    Int?
  color       String?      @db.VarChar(7)
  isActive    Boolean      @default(true) @map("is_active")

  /// Phòng ban quản lý (cấp/thu hồi quyền book). Optional.
  managingDepartmentId String? @map("managing_department_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  managingDepartment Department?     @relation("ResourceDepartment", fields: [managingDepartmentId], references: [id], onDelete: SetNull)
  bookings           EventResource[]

  @@unique([organizationId, name])
  @@index([organizationId, kind, isActive])
  @@map("resources")
}

// ──────────────────────────────────────────────────────────────────────
// F7.3 — Calendar follow (per-user "who I'm watching")
//
// Asymmetric subscription between Employees: follower opts-in to see
// followed's events on their calendar. ExternalCalendarLink (Google /
// Microsoft sync) is deferred to F7.4 — see plans/features.md.
// ──────────────────────────────────────────────────────────────────────

model CalendarFollow {
  id         String   @id @default(uuid())
  followerId String   @map("follower_id")
  followedId String   @map("followed_id")
  /// Hex color picked from a fixed palette at follow-create. Stable across
  /// sessions so a colleague always shows the same color in your sidebar +
  /// events. Service rotates through the palette to avoid repeats per
  /// follower.
  color      String   @default("#3b82f6") @db.VarChar(9)
  createdAt  DateTime @default(now()) @map("created_at")

  follower Employee @relation("CalendarFollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  followed Employee @relation("CalendarFollowFollowed", fields: [followedId], references: [id], onDelete: Cascade)

  @@unique([followerId, followedId])
  @@index([followerId])
  @@index([followedId])
  @@map("calendar_follows")
}

// N:M join — 1 event ↔ N resources. Conflict guard: same resource +
// overlapping [start, end) at the service layer (event.service.ts).
model EventResource {
  id         String @id @default(uuid())
  eventId    String @map("event_id")
  resourceId String @map("resource_id")

  /// Snapshot lúc book — phục vụ audit khi resource đổi tên / soft-delete.
  resourceNameSnapshot String? @map("resource_name_snapshot") @db.VarChar(127)

  createdAt DateTime @default(now()) @map("created_at")

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /// RESTRICT: không xoá resource khi còn booking — caller phải cancel
  /// booking trước (tránh dangling refs).
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Restrict)

  @@unique([eventId, resourceId])
  @@index([resourceId])
  @@map("event_resources")
}

// ──────────────────────────────────────────────────────────────────────
// Work app (Phase 1B) — Project + ProjectMember + TaskSection.
//
// Project = container cho task. Member roles: OWNER (1+), EDITOR (sửa
// task), COMMENTER (bình luận), VIEWER (chỉ xem). TaskSection là cột
// Kanban — tạo mặc định 3 cột "Cần làm / Đang làm / Hoàn thành" khi
// project được tạo. Task entity sẽ ship Phase 2.
// ──────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  DONE
}

enum ProjectVisibility {
  PRIVATE
  PUBLIC
}

enum ProjectRole {
  OWNER
  EDITOR
  COMMENTER
  VIEWER
}

model Project {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  ownerId        String            @map("owner_id")
  name           String            @db.VarChar(127)
  description    String?           @db.Text
  status         ProjectStatus     @default(ACTIVE)
  visibility     ProjectVisibility @default(PRIVATE)
  color          String?           @db.VarChar(9)
  icon           String?           @db.VarChar(31)
  /// Counter for human-friendly task code "PRJ-1", "PRJ-2", ...
  /// Used by Task module (built later) — atomic increment in service.
  taskCounter    Int               @default(0) @map("task_counter")
  /// 3-8 chars in hoa, unique trong org. VD "WORK", "MKT".
  slug           String            @db.VarChar(8)
  startDate      DateTime?         @map("start_date") @db.Date
  dueDate        DateTime?         @map("due_date") @db.Date
  archivedAt     DateTime?         @map("archived_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  owner    User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members  ProjectMember[]
  sections TaskSection[]
  tasks    Task[]

  @@unique([organizationId, slug])
  @@index([organizationId, status, archivedAt])
  @@map("projects")
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String      @map("project_id")
  userId    String      @map("user_id")
  role      ProjectRole @default(EDITOR)
  joinedAt  DateTime    @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectMember", fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model TaskSection {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  name      String @db.VarChar(63)
  order     Int    @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId, order])
  @@map("task_sections")
}

// ──────────────────────────────────────────────────────────────────────
// Work app (Phase 2) — Task + TaskWatcher.
//
// Task = đơn vị công việc trong Project. Code "PRJ-15" sinh atomically
// qua Project.taskCounter. Subtask 1-level (parentTaskId). Watcher = User
// follow task (auto-add reporter + assignee). assigneeId/reporterId →
// User (NOT Employee) — entity trung tâm per F8 decision #17.
// ──────────────────────────────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  projectId       String       @map("project_id")
  sectionId       String?      @map("section_id")
  parentTaskId    String?      @map("parent_task_id")
  /// "PRJ-15" — slug + sequential. Unique trong org. Service generates
  /// by atomically incrementing Project.taskCounter.
  code            String       @db.VarChar(15)
  title           String       @db.VarChar(255)
  description     String?      @db.Text
  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(MEDIUM)
  assigneeId      String?      @map("assignee_id")
  reporterId      String       @map("reporter_id")
  startDate       DateTime?    @map("start_date") @db.Date
  dueDate         DateTime?    @map("due_date") @db.Date
  estimateMinutes Int?         @map("estimate_minutes")
  actualMinutes   Int?         @map("actual_minutes")
  /// Drag-sort trong section. Float midpoint → insert-between không reindex.
  order           Float        @default(0)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  project  Project       @relation(fields: [projectId], references: [id])
  section  TaskSection?  @relation(fields: [sectionId], references: [id])
  parent   Task?         @relation("TaskSubtasks", fields: [parentTaskId], references: [id])
  subtasks Task[]        @relation("TaskSubtasks")
  assignee User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter User          @relation("TaskReporter", fields: [reporterId], references: [id])
  watchers TaskWatcher[]
  timers   TaskTimer[]

  @@unique([organizationId, code])
  @@index([projectId, status, deletedAt])
  @@index([assigneeId, status, deletedAt])
  @@index([projectId, sectionId, order])
  @@map("tasks")
}

model TaskWatcher {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskWatcher", fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@map("task_watchers")
}

/// F8 Phase 7 — one row per work session per (task, user). Many sessions
/// per (task, user) possible. Service stamps `stoppedAt` + `minutes` on
/// stop; while running, both are null. `stoppedAt IS NULL` is the
/// canonical "running" predicate — indexed for fast lookups.
model TaskTimer {
  id        String    @id @default(uuid())
  taskId    String    @map("task_id")
  userId    String    @map("user_id")
  startedAt DateTime  @map("started_at")
  /// null while running. Service stamps when stop() is called.
  stoppedAt DateTime? @map("stopped_at")
  /// Computed on stop: minutes between startedAt and stoppedAt.
  /// null while running so summary queries can use SUM(minutes).
  minutes   Int?
  /// Free-text note user can attach when stopping ("fixed bug X", etc.).
  note      String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskTimerUser", fields: [userId], references: [id])

  @@index([userId, startedAt])
  @@index([taskId, startedAt])
  @@index([userId, stoppedAt])
  @@map("task_timers")
}

// ──────────────────────────────────────────────────────────────────────
// Payroll (F9) — Phase 1A schema foundation.
//
// PayrollConfig = bảng cấu hình per Org per year (mức giảm trừ, hệ số
// trần BH, bậc thuế lũy tiến, ...). HR cập nhật qua /settings/payroll
// khi luật thay đổi — không cần redeploy.
//
// PayrollPeriod = kỳ lương 1 tháng. HR mở period → pull data → review →
// CLOSE → PAY. PAID là trạng thái bất biến.
//
// PayrollItem = 1 row / NV × 1 kỳ. Snapshot mọi input + output để khi
// luật/lương đổi giữa kỳ vẫn truy lại được.
// ──────────────────────────────────────────────────────────────────────

enum RegionTier {
  REGION_I
  REGION_II
  REGION_III
  REGION_IV
}

enum PayrollStatus {
  DRAFT
  CLOSED
  PAID
}

/// Config per Org per year cho payroll. Mọi mức cứng / hệ số / bậc thuế
/// lưu ở đây — HR update khi luật thay đổi, không cần redeploy.
model PayrollConfig {
  id                     String   @id @default(uuid())
  organizationId         String   @map("organization_id")
  year                   Int
  /// Mức giảm trừ bản thân (VND/tháng). 2024 = 11_000_000.
  personalDeduction      Decimal  @map("personal_deduction") @db.Decimal(15, 2)
  /// Mức giảm trừ người phụ thuộc (VND/người/tháng). 2024 = 4_400_000.
  dependentDeduction     Decimal  @map("dependent_deduction") @db.Decimal(15, 2)
  /// Mức lương tối thiểu vùng (VND/tháng). JSON: { I, II, III, IV }.
  regionMinWageJson      Json     @map("region_min_wage_json")
  /// Hệ số trần đóng BH (BHXH/BHYT/BHTN) = N × regionMinWage. Default 20.
  insuranceCapMultiplier Decimal  @default("20") @map("insurance_cap_multiplier") @db.Decimal(5, 2)
  /// Tỷ lệ % NLĐ trừ. Default 8/1.5/1 = 10.5%.
  bhxhRate               Decimal  @default("8") @map("bhxh_rate") @db.Decimal(5, 2)
  bhytRate               Decimal  @default("1.5") @map("bhyt_rate") @db.Decimal(5, 2)
  bhtnRate               Decimal  @default("1") @map("bhtn_rate") @db.Decimal(5, 2)
  /// Hệ số OT theo bucket. JSON:
  /// { weekday: 1.5, weekend: 2.0, holiday: 3.0, night: 1.3 }
  otRatesJson            Json     @map("ot_rates_json")
  /// Bảng bậc thuế TNCN lũy tiến. JSON array, mỗi entry { upto, rate }.
  /// upto null hoặc thiếu = bậc cuối cùng (vô cực).
  taxBracketsJson        Json     @map("tax_brackets_json")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, year])
  @@map("payroll_configs")
}

/// Kỳ lương 1 tháng. HR tạo → tự pull data → review → CLOSE → PAY.
/// PAID = bất biến.
model PayrollPeriod {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  /// "2026-05" — 1 period per org per month.
  monthKey       String        @map("month_key") @db.VarChar(7)
  year           Int
  month          Int // 1-12
  status         PayrollStatus @default(DRAFT)
  closedAt       DateTime?     @map("closed_at")
  closedById     String?       @map("closed_by_id")
  paidAt         DateTime?     @map("paid_at")
  paidById       String?       @map("paid_by_id")
  note           String?       @db.Text
  createdById    String        @map("created_by_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  items PayrollItem[]

  @@unique([organizationId, monthKey])
  @@index([organizationId, status])
  @@map("payroll_periods")
}

/// 1 row = 1 NV × 1 kỳ. SNAPSHOT mọi thông tin tại thời điểm compute.
model PayrollItem {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  periodId       String @map("period_id")
  employeeId     String @map("employee_id")

  baseSalary Decimal    @map("base_salary") @db.Decimal(15, 2)
  dependents Int
  region     RegionTier

  standardWorkdays  Int     @map("standard_workdays")
  actualWorkdays    Decimal @map("actual_workdays") @db.Decimal(5, 2)
  lateMinutes       Int     @default(0) @map("late_minutes")
  earlyLeaveMinutes Int     @default(0) @map("early_leave_minutes")
  otMinutesWeekday  Int     @default(0) @map("ot_minutes_weekday")
  otMinutesWeekend  Int     @default(0) @map("ot_minutes_weekend")
  otMinutesHoliday  Int     @default(0) @map("ot_minutes_holiday")

  /// Free-form allowances. JSON array:
  /// [{ name, amount, taxable: boolean, insurable: boolean }]
  allowancesJson Json @map("allowances_json")
  /// [{ name, amount, note? }]
  deductionsJson Json @map("deductions_json")

  /// Computed columns — set by calculator.compute(). 0 trước khi compute.
  grossIncome    Decimal @default("0") @map("gross_income") @db.Decimal(15, 2)
  insurableBase  Decimal @default("0") @map("insurable_base") @db.Decimal(15, 2)
  bhxhEmployee   Decimal @default("0") @map("bhxh_employee") @db.Decimal(15, 2)
  bhytEmployee   Decimal @default("0") @map("bhyt_employee") @db.Decimal(15, 2)
  bhtnEmployee   Decimal @default("0") @map("bhtn_employee") @db.Decimal(15, 2)
  insuranceTotal Decimal @default("0") @map("insurance_total") @db.Decimal(15, 2)
  taxableIncome  Decimal @default("0") @map("taxable_income") @db.Decimal(15, 2)
  taxAmount      Decimal @default("0") @map("tax_amount") @db.Decimal(15, 2)
  netPay         Decimal @default("0") @map("net_pay") @db.Decimal(15, 2)

  computeNote String? @map("compute_note") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  period   PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee Employee      @relation("EmployeePayroll", fields: [employeeId], references: [id])

  @@unique([periodId, employeeId])
  @@index([organizationId, employeeId])
  @@map("payroll_items")
}

// ──────────────────────────────────────────────────────────────────────
// Onboarding (F10) — Phase 1 schema foundation.
//
// OnboardingTemplate = bộ task khuôn mẫu admin HRM cấu hình ở /settings/
// onboarding. Mỗi org có thể tạo nhiều mẫu (vd "Dev mới", "Sales mới"),
// 1 mẫu được đánh dấu isDefault để auto-apply khi Employee được tạo.
//
// OnboardingPlan = instance áp 1 template lên 1 Employee. SNAPSHOT
// templateName để khi mẫu gốc bị đổi/xoá vẫn truy lại được.
//
// OnboardingTask = task cụ thể trong 1 plan. assigneeId resolved từ
// defaultAssigneeRole của template-task (HR / MANAGER / EMPLOYEE / IT /
// CUSTOM) lúc plan được tạo (Phase 2).
// ──────────────────────────────────────────────────────────────────────

enum AssigneeRole {
  HR
  MANAGER
  EMPLOYEE
  IT
  CUSTOM
}

enum OnboardingPlanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum OnboardingTaskStatus {
  TODO
  DONE
}

model OnboardingTemplate {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String    @db.VarChar(127)
  description    String?   @db.Text
  isActive       Boolean   @default(true) @map("is_active")
  /// 1 template per org có isDefault=true. Auto-apply khi Employee created.
  isDefault      Boolean   @default(false) @map("is_default")
  createdById    String    @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tasks OnboardingTemplateTask[]
  plans OnboardingPlan[]

  @@index([organizationId, isActive, deletedAt])
  @@map("onboarding_templates")
}

model OnboardingTemplateTask {
  id                    String       @id @default(uuid())
  templateId            String       @map("template_id")
  title                 String       @db.VarChar(255)
  /// Richtext HTML (Tiptap). Can paste images as base64.
  description           String?      @db.Text
  order                 Float        @default(0)
  defaultAssigneeRole   AssigneeRole @default(HR) @map("default_assignee_role")
  /// Only used when role=CUSTOM. Reference to User.id.
  defaultAssigneeUserId String?      @map("default_assignee_user_id")
  /// Days from employee.hireDate. 0 = same day, 7 = within a week, -3 = 3 days before.
  dueOffsetDays         Int          @default(0) @map("due_offset_days")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, order])
  @@map("onboarding_template_tasks")
}

model OnboardingPlan {
  id                   String               @id @default(uuid())
  organizationId       String               @map("organization_id")
  employeeId           String               @unique @map("employee_id")
  templateId           String               @map("template_id")
  /// Snapshot of template name at create time — original template can be renamed/deleted.
  templateNameSnapshot String               @map("template_name_snapshot") @db.VarChar(127)
  status               OnboardingPlanStatus @default(PENDING)
  startedAt            DateTime?            @map("started_at")
  completedAt          DateTime?            @map("completed_at")
  createdById          String               @map("created_by_id")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  template OnboardingTemplate @relation(fields: [templateId], references: [id])
  employee Employee           @relation(fields: [employeeId], references: [id])
  tasks    OnboardingTask[]

  @@index([organizationId, status])
  @@map("onboarding_plans")
}

model OnboardingTask {
  id             String               @id @default(uuid())
  organizationId String               @map("organization_id")
  planId         String               @map("plan_id")
  /// Audit pointer back to template task. Null if HR added the task manually after plan creation.
  templateTaskId String?              @map("template_task_id")
  title          String               @db.VarChar(255)
  description    String?              @db.Text
  order          Float                @default(0)
  assigneeId     String               @map("assignee_id")
  dueDate        DateTime?            @map("due_date") @db.Date
  status         OnboardingTaskStatus @default(TODO)
  completedAt    DateTime?            @map("completed_at")
  completedById  String?              @map("completed_by_id")
  completedNote  String?              @map("completed_note") @db.Text
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  plan OnboardingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, order])
  @@index([assigneeId, status])
  @@map("onboarding_tasks")
}

// ─────────────────────────────────────────────────────────────────────
// F11 — Recruitment / ATS (Phase 1: Job, Candidate, Application)
// Phase 2 will add JobBoardIntegration + JobBoardPosting.
// Phase 3 will add Interview, Scorecard, Offer.
// See docs/plans/f11-ats.md.
// ─────────────────────────────────────────────────────────────────────

enum JobStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  FILLED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

/// Pipeline column kind. Name/order are user-configurable, but the kind
/// is fixed so analytics (funnel, time-to-hire) stays comparable across
/// orgs. REJECTED is a sink stage rendered outside the main pipeline.
enum JobStageKind {
  SOURCED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum CandidateSource {
  MANUAL
  REFERRAL
  TOPCV
  ITVIEC
  TALENT_VN
  CAREER_PAGE
  OTHER
}

model Job {
  id               String     @id @default(uuid())
  organizationId   String     @map("organization_id")
  /// Per-org human-friendly code, e.g. "JOB-15". Generated by sequential
  /// counter at create time. Unique within an Org.
  code             String
  /// URL slug "<title>-<random>". Unique globally to make public career
  /// pages straightforward in Phase 5.
  slug             String     @unique
  title            String     @db.VarChar(255)
  description      String     @db.Text
  requirements     String     @db.Text
  benefits         String?    @db.Text
  departmentId    String?    @map("department_id")
  hiringManagerId  String?    @map("hiring_manager_id")
  createdById      String     @map("created_by_id")
  status           JobStatus  @default(DRAFT)
  jobType          JobType    @map("job_type")
  workMode         WorkMode   @map("work_mode")
  /// JSON array: [{ city, district?, address? }]
  workAddresses    Json       @default("[]") @map("work_addresses")
  experienceMin    Int?       @map("experience_min")
  experienceMax    Int?       @map("experience_max")
  salaryMin        Decimal?   @map("salary_min") @db.Decimal(15, 2)
  salaryMax        Decimal?   @map("salary_max") @db.Decimal(15, 2)
  salaryNegotiable Boolean    @default(false) @map("salary_negotiable")
  currency         String     @default("VND")
  /// Required skills, plain string list for now; Phase 5 may move to Tag.
  requiredSkills   String[]   @map("required_skills")
  niceToHaveSkills String[]   @map("nice_to_have_skills")
  headcount        Int        @default(1)
  isUrgent         Boolean    @default(false) @map("is_urgent")
  expiresAt        DateTime?  @map("expires_at")
  publishedAt      DateTime?  @map("published_at")
  closedAt         DateTime?  @map("closed_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  department     Department?  @relation("JobDepartment", fields: [departmentId], references: [id])
  hiringManager  User?        @relation("JobHiringManager", fields: [hiringManagerId], references: [id])
  createdBy      User         @relation("JobCreatedBy", fields: [createdById], references: [id])
  stages         JobStage[]
  applications   Application[]
  postings       JobBoardPosting[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([organizationId, departmentId])
  @@map("jobs")
}

model JobStage {
  id        String       @id @default(uuid())
  jobId     String       @map("job_id")
  kind      JobStageKind
  name      String       @db.VarChar(127)
  /// Float ordering so reorder is a single-row update.
  order     Float        @default(0)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([jobId, order])
  @@map("job_stages")
}

model Candidate {
  id              String          @id @default(uuid())
  organizationId  String          @map("organization_id")
  fullName        String          @map("full_name") @db.VarChar(255)
  email           String
  phone           String?
  /// One-line headline shown in lists (e.g. "Senior Backend at FPT").
  headline        String?
  location        String?
  linkedinUrl     String?         @map("linkedin_url")
  source          CandidateSource @default(MANUAL)
  /// Board-specific metadata kept opaque (externalApplicationId, raw
  /// payload). Not used for joins — search by externalId on Application.
  sourceMeta      Json?           @map("source_meta")
  /// Set when candidate is hired and a User account is created.
  userId          String?         @unique @map("user_id")
  /// Set when candidate is hired and an Employee record is created.
  employeeId      String?         @unique @map("employee_id")
  createdById     String          @map("created_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  organization Organization      @relation(fields: [organizationId], references: [id])
  user         User?             @relation("CandidateUser", fields: [userId], references: [id])
  employee     Employee?         @relation("CandidateEmployee", fields: [employeeId], references: [id])
  createdBy    User              @relation("CandidateCreatedBy", fields: [createdById], references: [id])
  resumes      CandidateResume[]
  applications Application[]

  @@unique([organizationId, email])
  @@index([organizationId, source])
  @@index([organizationId, deletedAt])
  @@map("candidates")
}

model CandidateResume {
  id           String   @id @default(uuid())
  candidateId  String   @map("candidate_id")
  filename     String   @db.VarChar(255)
  url          String
  mimeType     String   @map("mime_type") @db.VarChar(127)
  sizeBytes    Int      @map("size_bytes")
  isActive     Boolean  @default(true) @map("is_active")
  /// Optional structured parse output (skills, education, experience).
  parsedMeta   Json?    @map("parsed_meta")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  candidate    Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applications Application[] @relation("ApplicationResume")

  @@index([candidateId, isActive])
  @@map("candidate_resumes")
}

model Application {
  id              String           @id @default(uuid())
  organizationId  String           @map("organization_id")
  candidateId     String           @map("candidate_id")
  jobId           String           @map("job_id")
  stageId         String           @map("stage_id")
  /// Snapshot of which resume was used for this application; candidate
  /// can upload a newer one without rewriting this row.
  resumeId        String?          @map("resume_id")
  coverLetter     String?          @db.Text
  expectedSalary  Decimal?         @map("expected_salary") @db.Decimal(15, 2)
  appliedAt       DateTime         @default(now()) @map("applied_at")
  rejectedAt      DateTime?        @map("rejected_at")
  rejectReason    String?          @map("reject_reason")
  withdrawnAt     DateTime?        @map("withdrawn_at")
  /// External id from job board (for dedup on webhook redelivery).
  externalId      String?          @map("external_id")
  externalSource  CandidateSource? @map("external_source")
  /// Append-only stage transition log. Shape:
  /// [{ fromStageId: string|null, toStageId: string, userId: string,
  ///    reason?: string, at: ISO }]
  stageHistory    Json             @default("[]") @map("stage_history")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id])
  candidate    Candidate        @relation(fields: [candidateId], references: [id])
  job          Job              @relation(fields: [jobId], references: [id])
  stage        JobStage         @relation(fields: [stageId], references: [id])
  resume       CandidateResume? @relation("ApplicationResume", fields: [resumeId], references: [id])

  @@unique([candidateId, jobId])
  @@index([organizationId, stageId])
  @@index([organizationId, jobId])
  @@index([externalSource, externalId])
  @@map("applications")
}

// ─────────────────────────────────────────────────────────────────────
// F11 Phase 2 — Job board integration (talent.vn + TopCV + ITviec).
// 1 OrgApiKey-like row per (org, board); JobBoardPosting tracks which
// jobs have been pushed where, plus the latest sync status.
// See docs/plans/f11-ats.md §6 + §3.3.
// ─────────────────────────────────────────────────────────────────────

enum JobBoard {
  TOPCV
  ITVIEC
  TALENT_VN
}

enum PostingSyncStatus {
  PENDING
  SUCCESS
  FAILED
  CLOSED
}

model JobBoardIntegration {
  id                   String   @id @default(uuid())
  organizationId       String   @map("organization_id")
  board                JobBoard
  /// AES-256-GCM ciphertext of `{ apiKey, ...board-specific }`. Stored
  /// encrypted because tokens are write-mostly secrets — the FE only
  /// shows the last 4 chars.
  credentialsEncrypted String   @map("credentials_encrypted")
  /// Optional: secret used to verify the HMAC signature on inbound
  /// webhooks from the board.
  webhookSecret        String?  @map("webhook_secret")
  isActive             Boolean  @default(false) @map("is_active")
  lastSyncAt           DateTime? @map("last_sync_at")
  lastError            String?   @map("last_error")
  createdById          String    @map("created_by_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  postings     JobBoardPosting[]

  @@unique([organizationId, board])
  @@map("job_board_integrations")
}

model JobBoardPosting {
  id             String            @id @default(uuid())
  jobId          String            @map("job_id")
  integrationId  String            @map("integration_id")
  /// ID assigned by the external board after a successful publish.
  externalId     String            @map("external_id")
  externalUrl    String?           @map("external_url")
  lastSyncStatus PostingSyncStatus @default(PENDING) @map("last_sync_status")
  lastSyncError  String?           @map("last_sync_error")
  publishedAt    DateTime?         @map("published_at")
  closedAt       DateTime?         @map("closed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  job         Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  integration JobBoardIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([jobId, integrationId])
  @@unique([integrationId, externalId])
  @@map("job_board_postings")
}
