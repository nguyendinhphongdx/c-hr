// To switch DB engine: `pnpm db:switch <postgresql|mysql|sqlite>`
// (Updates the `provider` line below. Migrations are engine-specific —
//  delete prisma/migrations/ then `pnpm prisma:migrate` after switching.)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role hierarchy: sysowner ⊃ admin (Org) ⊃ appadmin (per-app, see AppAdmin) ⊃ user.
// See docs/decisions/0003-no-permission-engine.md.
enum Role {
  sysowner
  admin
  user
}

// Bounded contexts that ship as separate "apps" inside an Organization.
// Add new codes when scaffolding the matching apps/<context>/ folder.
enum AppCode {
  HRM
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DeviceBrand {
  ZKTECO
  HIKVISION
  SUPREMA
  OTHER
}

enum AttendanceSource {
  DEVICE
  CORRECTION
  MANUAL_HR
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  timezone  String    @default("Asia/Ho_Chi_Minh")
  currency  String    @default("VND")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users User[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  name           String?
  avatar         String?
  // Personal title set by the user (e.g. "Senior Engineer"). Distinct from
  // Employee.title (the formal job title set by HR).
  title          String?
  // Personal info — moved here from Employee so it travels with the
  // person, not the employment record.
  dob            DateTime?
  gender         Gender?
  phone          String?
  role           Role      @default(user)
  // Null for sysowner (no Org). Required for role=admin/user — enforced in app code.
  organizationId String?   @map("organization_id")
  // 1-1 link to Employee. Null until HR provisions the employee record.
  employeeId     String?   @unique @map("employee_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  employee     Employee?     @relation(fields: [employeeId], references: [id])
  appAdmins    AppAdmin[]
  comments     Comment[]
  activities   Activity[]

  eventsOwned      Event[]         @relation("EventOwner")
  eventsCreated    Event[]         @relation("EventCreatedBy")
  eventAttendances EventAttendee[] @relation("EventAttendee")

  @@map("users")
}

// Per-app admin grant for users with role=user. Users with role=admin or
// sysowner inherit appadmin permissions (no record needed for them).
// See docs/decisions/0003-no-permission-engine.md.
model AppAdmin {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  appCode        AppCode  @map("app_code")
  // The user (admin Org) who granted this. Null if granted via seed/CLI.
  grantedBy      String?  @map("granted_by")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId, appCode])
  @@index([organizationId, appCode])
  @@map("app_admins")
}

// Append-only log of audit-relevant actions (org structure changes, permission
// grants, approval workflow). Written async by AuditInterceptor.
// See docs/decisions/0002-audit-log.md.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  actorIpAddress String?  @map("actor_ip_address")
  actorUserAgent String?  @map("actor_user_agent")
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  diff           Json?
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// Phòng ban — nested via parentId, owns a manager (Employee). Source of
// truth for the org chart per ADR 0004.
model Department {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  parentId       String?   @map("parent_id")
  managerId      String?   @map("manager_id")
  name           String
  /// Optional human-friendly code (e.g. "ENG-01"). Unique within an Org when set.
  code           String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  manager   Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  employees Employee[]   @relation("EmployeeDepartment")

  managedResources Resource[] @relation("ResourceDepartment")

  @@unique([organizationId, code])
  @@index([organizationId, parentId])
  @@index([organizationId, managerId])
  @@map("departments")
}

// Hồ sơ nhân viên trong Org. 1-1 với User qua User.employeeId (FK lives
// on User; Employee.user is the back-relation only — domain.md keeps a
// single source of truth for the link).
//
// Personal info (name, email, dob, gender, phone) lives on User. Employee
// only carries employment-record fields (title, dept, hireDate, status).
model Employee {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  departmentId    String?        @map("department_id")
  /// Required, unique within an Org. Generated by HR (e.g. "EMP-0001").
  code            String
  /// Formal job title set by HR. Distinct from User.title (personal).
  title           String?
  hireDate        DateTime?      @map("hire_date")
  terminationDate DateTime?      @map("termination_date")
  status          EmployeeStatus @default(ACTIVE)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  department         Department?     @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  managedDepartments Department[]    @relation("DepartmentManager")
  /// 1-1 back-relation. FK is on User.employeeId.
  user               User?
  attendanceLogs     AttendanceLog[]

  requestsAsRequester Request[] @relation("RequestRequester")
  requestsAsApprover  Request[] @relation("RequestApprover")

  @@unique([organizationId, code])
  @@index([organizationId, departmentId])
  @@index([organizationId, status])
  @@map("employees")
}

// Lịch làm việc — mỗi Org có 1 schedule isDefault=true. Áp cho mọi
// employee (MVP). Thêm Employee.workScheduleId chỉ khi cần override.
model WorkSchedule {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  isDefault      Boolean   @default(false) @map("is_default")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  shifts WorkShift[]

  @@index([organizationId, isDefault])
  @@map("work_schedules")
}

// Một ca làm trong schedule: "Ca chính T2-T6", "Sáng T7", "Ca đêm".
// startTime/endTime dạng "HH:MM" 24h. crossesMidnight=true khi end <= start.
model WorkShift {
  id               String   @id @default(uuid())
  workScheduleId   String   @map("work_schedule_id")
  name             String
  startTime        String   @map("start_time")
  endTime          String   @map("end_time")
  /// ISO weekdays: 1=Mon ... 7=Sun. MVP constraint: shifts trong cùng
  /// schedule không được trùng day — validated ở service layer.
  daysOfWeek       Int[]    @map("days_of_week")
  breakMinutes     Int      @default(0) @map("break_minutes")
  lateGraceMinutes Int      @default(15) @map("late_grace_minutes")
  crossesMidnight  Boolean  @default(false) @map("crosses_midnight")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)

  @@map("work_shifts")
}

// Đầu đọc chấm công đăng ký với Org. Push events qua HTTP với token.
model AttendanceDevice {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  brand          DeviceBrand
  serial         String
  /// Bumped khi regenerate-token để invalidate JWT cũ. JWT push include `v`,
  /// server reject nếu `v != device.version`.
  version        Int         @default(1)
  name           String
  ipAddress      String?     @map("ip_address")
  lastSeenAt     DateTime?   @map("last_seen_at")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  logs AttendanceLog[]

  @@unique([organizationId, serial])
  @@map("attendance_devices")
}

// 1 row = 1 ngày của 1 employee. Push lần thứ nhất tạo row, push tiếp theo
// update checkInAt = MIN, checkOutAt = MAX. Replay của cùng eventLogId là
// no-op qua unique (deviceId, eventLogId).
model AttendanceLog {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  /// Nullable: events từ device có employeeCode chưa map được Employee row
  /// (HR chưa tạo) sẽ được lưu với employeeId=null + employeeCode=<raw>.
  /// Khi Employee được tạo/update với code đó → reconcile gán employeeId.
  employeeId     String?          @map("employee_id")
  /// Raw employee code từ device payload. Lưu cho mọi row có nguồn từ device,
  /// để reconcile được orphan logs sau khi Employee tạo (Postgres NULL trong
  /// unique không chặn → nhiều orphan rows / day cùng tồn tại OK).
  employeeCode   String?          @map("employee_code")
  date           DateTime         @db.Date
  checkInAt      DateTime?        @map("check_in_at")
  checkOutAt     DateTime?        @map("check_out_at")
  source         AttendanceSource
  deviceId       String?          @map("device_id")
  /// Idempotency key gửi kèm payload từ device (event id nội bộ của nó).
  /// Cặp (deviceId, eventLogId) unique → replay không tạo dup.
  eventLogId     String?          @map("event_log_id")
  note           String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  employee Employee?         @relation(fields: [employeeId], references: [id])
  device   AttendanceDevice? @relation(fields: [deviceId], references: [id])

  @@unique([employeeId, date])
  @@unique([deviceId, eventLogId])
  @@index([organizationId, date])
  @@index([organizationId, employeeCode])
  @@map("attendance_logs")
}

// ──────────────────────────────────────────────────────────────────────
// Universal Request engine (F5) — replaces F4's per-type tables.
// Một bảng `requests` với polymorphic `data: Json` validated theo
// `RequestGroup.fieldsSchema`. Side-effects khi approve dispatch theo
// group code (registry trong src/apps/requests/side-effects/).
// Xem ADR 0006.
// ──────────────────────────────────────────────────────────────────────

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// Định nghĩa loại đơn — system-wide (1 record / code chung mọi Org).
// MVP seed cứng (leave, checkin, checkout). Form-builder UI cho admin
// Org tự thêm/sửa schema sẽ làm sau (xem F5.2 trong plans/features.md).
model RequestGroup {
  id           String   @id @default(uuid())
  /// "leave", "checkin", "checkout", ... — unique system-wide.
  code         String   @unique
  name         String
  description  String?
  /// JSON theo dạng { fields: [{ key, label, type, required, options?, ... }] }.
  /// BE validate request.data trước save; FE dùng render dynamic form.
  fieldsSchema Json     @map("fields_schema")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  requests Request[]

  @@map("request_groups")
}

// Mọi đơn từ. data là object theo group.fieldsSchema (vd leave có
// type/startDate/endDate; checkin có date/requestedCheckInAt/reason; ...).
model Request {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  groupId        String        @map("group_id")
  requesterId    String        @map("requester_id")
  approverId     String?       @map("approver_id")
  status         RequestStatus @default(PENDING)
  title          String?       @map("title")
  data           Json
  decisionNote   String?       @map("decision_note")
  decidedAt      DateTime?     @map("decided_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  group     RequestGroup @relation(fields: [groupId], references: [id])
  requester Employee     @relation("RequestRequester", fields: [requesterId], references: [id])
  approver  Employee?    @relation("RequestApprover", fields: [approverId], references: [id])

  @@index([organizationId, requesterId])
  @@index([organizationId, approverId, status])
  @@index([organizationId, groupId, status])
  @@map("requests")
}

// Generic comment — gắn vào bất kỳ object nào (Request, Employee, ...).
// objectType + objectId là pointer thuần (không FK) để giữ generic. Bảng
// tách khỏi `activities` vì comment mutable + body lớn (HTML), activity
// append-only + payload nhẹ. ADR/plan: F6 trong docs/plans/features.md.
model Comment {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  /// Pascal-case Prisma model name: "Request", "Employee", ...
  objectType String @map("object_type")
  objectId   String @map("object_id")

  userId   String @map("user_id")
  bodyHtml String @map("body_html")
  bodyText String @map("body_text")
  mentions Json?

  parentId String?   @map("parent_id")
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  isInternal Boolean @default(false) @map("is_internal")

  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([organizationId, objectType, objectId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

// Generic activity — append-only event log per object. Naming:
// "<object>.<verb>" (e.g. "request.commented", "request.approved").
// Side-effects nest under "<object>.side_effect.<name>". Distinct from
// `audit_logs` (admin compliance) — activities is for user-facing UX.
model Activity {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  objectType  String  @map("object_type")
  objectId    String  @map("object_id")
  /// Snapshot label for the feed (e.g. request title) — survives target rename.
  objectLabel String? @map("object_label")

  action String

  /// Null when the action is system-driven (cron, webhook, side-effect).
  userId   String? @map("user_id")
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, objectType, objectId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([action])
  @@map("activities")
}

// ──────────────────────────────────────────────────────────────────────
// Calendar (Feature 7) — MVP Phase 7.1
//
// Calendar là unified render layer. Sở hữu Event (cuộc họp + booking
// trong tương lai). MVP: single events only — không recurrence, không
// resource, không external sync, không follow. Các phần đó tách PR sau.
// ──────────────────────────────────────────────────────────────────────

enum EventStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
}

enum EventVisibility {
  DEFAULT
  PUBLIC
  PRIVATE
}

enum AttendeeResponse {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum EventProvider {
  LOCAL
  GOOGLE
  MICROSOFT
}

model Event {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  /// Owner = User sở hữu event (khác createdBy nếu admin tạo thay).
  /// Dùng User thay Employee — calendar đi theo người, không theo
  /// employment record (Employee có thể bị terminate/soft-delete;
  /// sysowner cũng không có Employee).
  ownerId     String @map("owner_id")
  createdById String @map("created_by_id")

  title         String  @db.VarChar(511)
  description   String? @db.Text
  location      String? @db.VarChar(1023)
  /// Conference URL (Google Meet / Zoom / Teams). Local v1: free-text.
  conferenceUrl String? @map("conference_url") @db.VarChar(1023)

  isAllDay Boolean  @default(false) @map("is_all_day")
  startAt  DateTime @map("start_at")
  /// Exclusive end ([start, end) — Google convention).
  endAt    DateTime @map("end_at")

  status     EventStatus     @default(CONFIRMED)
  visibility EventVisibility @default(DEFAULT)
  /// Override visibility: nobody but owner+attendees sees detail.
  isPrivate  Boolean         @default(false) @map("is_private")
  color      String?         @db.VarChar(7)

  /// LOCAL = tạo trong C-HR. GOOGLE/MICROSOFT = pull từ external (Phase 7.4).
  provider     EventProvider @default(LOCAL)
  /// Provider-side event id — set khi sync về.
  externalId   String?       @map("external_id") @db.VarChar(255)
  /// Optimistic concurrency token (etag) — sync correctness.
  externalEtag String?       @map("external_etag") @db.VarChar(127)
  /// RFC 5545 universal id — cross-provider dedupe.
  icalUid      String?       @map("ical_uid") @db.VarChar(511)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  owner     User @relation("EventOwner", fields: [ownerId], references: [id])
  createdBy User @relation("EventCreatedBy", fields: [createdById], references: [id])

  attendees EventAttendee[]
  resources EventResource[]

  @@index([organizationId, startAt, endAt])
  @@index([ownerId, startAt])
  @@index([provider, externalId])
  @@index([icalUid])
  @@map("events")
}

// Internal (User trong cùng Org) hoặc external (email) attendee.
// Một trong 2 phải set — enforce ở service layer (DB cho phép cả 2 null
// vì Prisma không có CHECK constraint cho XOR).
model EventAttendee {
  id      String @id @default(uuid())
  eventId String @map("event_id")

  userId      String? @map("user_id")
  email       String? @db.VarChar(127)
  /// Snapshot tên — cho external attendee không có User record.
  displayName String? @map("display_name") @db.VarChar(127)

  response    AttendeeResponse @default(PENDING)
  isOptional  Boolean          @default(false) @map("is_optional")
  isOrganizer Boolean          @default(false) @map("is_organizer")
  respondedAt DateTime?        @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation("EventAttendee", fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@unique([eventId, email])
  @@index([userId, response])
  @@map("event_attendees")
}

// ──────────────────────────────────────────────────────────────────────
// F7.2 — Resources & booking
//
// Resource = phòng họp / thiết bị / xe etc. Booking = N:M join từ Event
// sang Resource (1 event book được nhiều resource cùng lúc, vd phòng +
// máy chiếu). Conflict trên cùng resource là HARD (block) — khác với
// conflict trên người (soft warn) vì 1 phòng không thể chiếm song song.
// ──────────────────────────────────────────────────────────────────────

enum ResourceKind {
  ROOM
  EQUIPMENT
  VEHICLE
}

model Resource {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  kind        ResourceKind
  name        String       @db.VarChar(127)
  description String?      @db.Text
  /// Floor/building cho ROOM, garage cho VEHICLE...
  location    String?      @db.VarChar(255)
  /// Chỉ ý nghĩa với ROOM.
  capacity    Int?
  color       String?      @db.VarChar(7)
  isActive    Boolean      @default(true) @map("is_active")

  /// Phòng ban quản lý (cấp/thu hồi quyền book). Optional.
  managingDepartmentId String? @map("managing_department_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  managingDepartment Department?     @relation("ResourceDepartment", fields: [managingDepartmentId], references: [id], onDelete: SetNull)
  bookings           EventResource[]

  @@unique([organizationId, name])
  @@index([organizationId, kind, isActive])
  @@map("resources")
}

// N:M join — 1 event ↔ N resources. Conflict guard: same resource +
// overlapping [start, end) at the service layer (event.service.ts).
model EventResource {
  id         String @id @default(uuid())
  eventId    String @map("event_id")
  resourceId String @map("resource_id")

  /// Snapshot lúc book — phục vụ audit khi resource đổi tên / soft-delete.
  resourceNameSnapshot String? @map("resource_name_snapshot") @db.VarChar(127)

  createdAt DateTime @default(now()) @map("created_at")

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /// RESTRICT: không xoá resource khi còn booking — caller phải cancel
  /// booking trước (tránh dangling refs).
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Restrict)

  @@unique([eventId, resourceId])
  @@index([resourceId])
  @@map("event_resources")
}
