// To switch DB engine: `pnpm db:switch <postgresql|mysql|sqlite>`
// (Updates the `provider` line below. Migrations are engine-specific —
//  delete prisma/migrations/ then `pnpm prisma:migrate` after switching.)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role hierarchy: sysowner ⊃ admin (Org) ⊃ appadmin (per-app, see AppAdmin) ⊃ user.
// See docs/decisions/0003-no-permission-engine.md.
enum Role {
  sysowner
  admin
  user
}

// Bounded contexts that ship as separate "apps" inside an Organization.
// Add new codes when scaffolding the matching apps/<context>/ folder.
enum AppCode {
  HRM
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  timezone  String    @default("Asia/Ho_Chi_Minh")
  currency  String    @default("VND")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users User[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String?
  avatar         String?
  // Personal title set by the user (e.g. "Senior Engineer"). Distinct from
  // Employee.title (the formal job title set by HR).
  title          String?
  role           Role     @default(user)
  // Null for sysowner (no Org). Required for role=admin/user — enforced in app code.
  organizationId String?  @map("organization_id")
  // 1-1 link to Employee. Null until HR provisions the employee record.
  employeeId     String?  @unique @map("employee_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  employee     Employee?     @relation(fields: [employeeId], references: [id])
  appAdmins    AppAdmin[]

  @@map("users")
}

// Per-app admin grant for users with role=user. Users with role=admin or
// sysowner inherit appadmin permissions (no record needed for them).
// See docs/decisions/0003-no-permission-engine.md.
model AppAdmin {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  appCode        AppCode  @map("app_code")
  // The user (admin Org) who granted this. Null if granted via seed/CLI.
  grantedBy      String?  @map("granted_by")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId, appCode])
  @@index([organizationId, appCode])
  @@map("app_admins")
}

// Append-only log of audit-relevant actions (org structure changes, permission
// grants, approval workflow). Written async by AuditInterceptor.
// See docs/decisions/0002-audit-log.md.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  actorIpAddress String?  @map("actor_ip_address")
  actorUserAgent String?  @map("actor_user_agent")
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  diff           Json?
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// Phòng ban — nested via parentId, owns a manager (Employee). Source of
// truth for the org chart per ADR 0004.
model Department {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  parentId       String?   @map("parent_id")
  managerId      String?   @map("manager_id")
  name           String
  /// Optional human-friendly code (e.g. "ENG-01"). Unique within an Org when set.
  code           String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt      @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  manager   Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  employees Employee[]   @relation("EmployeeDepartment")

  @@unique([organizationId, code])
  @@index([organizationId, parentId])
  @@index([organizationId, managerId])
  @@map("departments")
}

// Hồ sơ nhân viên trong Org. 1-1 với User qua User.employeeId (FK lives
// on User; Employee.user is the back-relation only — domain.md keeps a
// single source of truth for the link).
model Employee {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  departmentId    String?        @map("department_id")
  /// Required, unique within an Org. Generated by HR (e.g. "EMP-0001").
  code            String
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  dob             DateTime?
  gender          Gender?
  phone           String?
  email           String
  /// Formal job title set by HR. Distinct from User.title (personal).
  title           String?
  hireDate        DateTime?      @map("hire_date")
  terminationDate DateTime?      @map("termination_date")
  status          EmployeeStatus @default(ACTIVE)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt      @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  department         Department?  @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  managedDepartments Department[] @relation("DepartmentManager")
  /// 1-1 back-relation. FK is on User.employeeId.
  user               User?

  @@unique([organizationId, code])
  @@index([organizationId, departmentId])
  @@index([organizationId, status])
  @@map("employees")
}
