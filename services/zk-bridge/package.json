{
  "name": "@c-hr/zk-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "C-HR pull-side adapter for ZKTeco devices — runs in customer LAN, pushes to C-HR cloud",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "poll:once": "ts-node src/index.ts --once",
    "reset-user": "node dist/cli/reset-user.js",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.14",
    "node-cron": "^3.0.3",
    "node-zklib": "^1.1.10",
    "sequelize": "^6.37.5",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
